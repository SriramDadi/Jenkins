pipeline {
    agent any
    stages {
        stage('Example Build') {
            steps {
                script{
                    sh """
                    echo "Hello, this is build"
                    """
                }

            }
        }
        stage('Example Test') {
            steps {
                script{
                    sh """
                    echo "Hello, this is test"
                    """
                }

            }
        }
        stage('Example Deploy') {
            steps {
                script{
                    sh """
                    echo "Hello, this is deploy"
                    """
                }

            }
        }
    }
}